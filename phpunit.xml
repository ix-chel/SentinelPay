<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
        <testsuite name="Concurrent">
            <directory>tests/Concurrent</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing" force="false"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file" force="false"/>
        <env name="BCRYPT_ROUNDS" value="4" force="false"/>
        <env name="BROADCAST_CONNECTION" value="null" force="false"/>
        <env name="CACHE_STORE" value="array" force="false"/>
        <!-- PostgreSQL required for SELECT FOR UPDATE (pessimistic locking) -->
        <!-- force="false" lets Docker Compose environment variables win over these defaults -->
        <env name="DB_CONNECTION" value="pgsql" force="false"/>
        <env name="DB_HOST" value="127.0.0.1" force="false"/>
        <env name="DB_PORT" value="5432" force="false"/>
        <env name="DB_DATABASE" value="sentinelpay_test" force="false"/>
        <env name="DB_USERNAME" value="postgres" force="false"/>
        <env name="DB_PASSWORD" value="postgres" force="false"/>
        <env name="MAIL_MAILER" value="array" force="false"/>
        <env name="QUEUE_CONNECTION" value="sync" force="false"/>
        <env name="SESSION_DRIVER" value="array" force="false"/>
        <env name="REDIS_CLIENT" value="phpredis" force="false"/>
        <env name="REDIS_HOST" value="127.0.0.1" force="false"/>
        <env name="REDIS_PASSWORD" value="secret" force="false"/>
        <!-- HMAC secret for security tests -->
        <env name="HMAC_SECRET" value="test-hmac-secret-key-for-phpunit" force="false"/>
        <env name="PULSE_ENABLED" value="false" force="false"/>
        <env name="TELESCOPE_ENABLED" value="false" force="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false" force="false"/>
    </php>
</phpunit>
